{
  "name": "@open-meet/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "bun --watch src/index.ts",
    "build": "bun run clean && bun run typecheck && bun run build:server",
    "build:server": "bun build src/index.ts --outdir dist --target bun",
    "start": "NODE_ENV=production bun dist/index.js",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.4",
    "@open-meet/feature-meeting-agent": "workspace:*",
    "hono": "^4.10.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
