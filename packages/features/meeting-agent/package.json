{
  "name": "@open-meet/feature-meeting-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun run typecheck && bun run build:package",
    "build:package": "bun build src/index.ts --outdir dist --target bun",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
